{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cpa-first.local/schemas/subject_tutorials.schema.json",
  "type": "object",
  "required": ["version", "source_policy", "step_order", "tutorials"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "source_policy": { "type": "string", "minLength": 1 },
    "step_order": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["foundation", "concept", "worked_example", "guided_practice", "past_exam_bridge", "variation"]
      },
      "minItems": 6,
      "maxItems": 6
    },
    "tutorials": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/tutorial" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "tutorial": {
      "type": "object",
      "required": [
        "tutorial_id",
        "subject_id",
        "exam_id",
        "phase_id",
        "phase_name",
        "subject_name",
        "assessment_type",
        "entry_topic",
        "title",
        "level",
        "objective",
        "concept_atoms",
        "steps"
      ],
      "properties": {
        "tutorial_id": { "type": "string", "minLength": 1 },
        "subject_id": { "type": "string", "minLength": 1 },
        "exam_id": { "type": "string", "enum": ["CPA", "CTA"] },
        "phase_id": { "type": "string", "minLength": 1 },
        "phase_name": { "type": "string", "minLength": 1 },
        "subject_name": { "type": "string", "minLength": 1 },
        "assessment_type": { "type": "string", "enum": ["objective", "written"] },
        "entry_topic": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "level": { "type": "string", "enum": ["intro_low"] },
        "objective": { "type": "string", "minLength": 1 },
        "concept_atoms": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "string", "minLength": 1 }
        },
        "steps": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "$ref": "#/$defs/step" }
        }
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "required": [
        "step_type",
        "label",
        "title",
        "difficulty",
        "core_explanation",
        "prompt",
        "model_answer",
        "learner_action",
        "checkpoints"
      ],
      "properties": {
        "step_type": {
          "type": "string",
          "enum": ["foundation", "concept", "worked_example", "guided_practice", "past_exam_bridge", "variation"]
        },
        "label": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "difficulty": { "type": "integer", "minimum": 1, "maximum": 2 },
        "core_explanation": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string", "minLength": 1 },
        "model_answer": { "type": "string", "minLength": 1 },
        "learner_action": { "type": "string", "minLength": 1 },
        "checkpoints": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  }
}
