{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cpa-first.local/schemas/evaluation_question.schema.json",
  "title": "EvaluationQuestion",
  "description": "AI 응시자 벤치마크용 객관식 모의 문제. 권리 가드레일에 안전한 자체 생성 자산만 허용.",
  "type": "object",
  "required": [
    "question_id",
    "exam",
    "subject",
    "unit",
    "stem",
    "choices",
    "correct_choice",
    "correct_answer",
    "rights_status",
    "review_status"
  ],
  "properties": {
    "question_id": {
      "type": "string"
    },
    "exam": {
      "type": "string",
      "enum": [
        "CPA_1"
      ]
    },
    "subject": {
      "type": "string",
      "description": "cpa_first.subjects 레지스트리와 동기화.",
      "enum": [
        "accounting",
        "tax",
        "business",
        "economics",
        "corporate_law",
        "management",
        "finance",
        "cost_accounting"
      ]
    },
    "unit": {
      "type": "string"
    },
    "applicable_year": {
      "type": [
        "integer",
        "null"
      ],
      "description": "세법은 적용연도 필수 (개정 분기). 회계는 K-IFRS 적용연도."
    },
    "stem": {
      "type": "string",
      "description": "문제 본문. 자체 생성 또는 공식 기출의 권리 처리된 버전."
    },
    "choices": {
      "type": "array",
      "minItems": 4,
      "maxItems": 5,
      "items": {
        "type": "string"
      }
    },
    "correct_choice": {
      "type": "integer",
      "minimum": 0,
      "description": "choices 배열의 0-기반 인덱스."
    },
    "correct_answer": {
      "type": "string",
      "description": "choices[correct_choice]와 반드시 일치하는 정답 보기 텍스트."
    },
    "explanation": {
      "type": "string",
      "description": "정답 해설. 채점 후 solver 출력과 비교용."
    },
    "concept_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_seconds": {
      "type": [
        "integer",
        "null"
      ],
      "description": "예상 풀이 시간 (벤치마크 기록용)."
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "easy",
        "mid",
        "hard"
      ],
      "description": "3단계 난이도 카테고리. easy=단일식, mid=2-3단계, hard=다단계+매력적 오답."
    },
    "difficulty_score": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "maximum": 5,
      "description": "1=trivial, 5=함정+다단계. easy=1-2, mid=3, hard=4-5."
    },
    "bloom_level": {
      "type": "string",
      "enum": [
        "remember",
        "understand",
        "apply",
        "analyze",
        "evaluate"
      ],
      "description": "Bloom 인지단계. CPA 1차 객관식은 보통 understand~analyze."
    },
    "attractor_traps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "문항이 노린 매력적 오답 종류 (검증 라운드에서 채움)."
    },
    "rights_status": {
      "type": "string",
      "enum": [
        "original_sample",
        "synthetic_seed",
        "rights_cleared_past_exam",
        "internal_draft"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "ai_draft",
        "ai_draft_verified",
        "ai_draft_revised",
        "expert_reviewed",
        "approved",
        "rejected"
      ]
    },
    "flagged_questionable": {
      "type": "boolean",
      "default": false,
      "description": "평가셋 자체 품질(정답키·보기 일관성 등) 이슈로 채점에서 제외할지 여부. 기본 false."
    },
    "questionable_reason": {
      "type": "string",
      "description": "flagged_questionable=true일 때 사유. 외부 검토자가 우선 확인할 단서."
    }
  },
  "additionalProperties": false
}
