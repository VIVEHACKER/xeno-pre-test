{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cpa-first.local/schemas/prescription.schema.json",
  "title": "Prescription",
  "description": "처방 엔진이 사용자에게 산출하는 일간/주간 공부 처방. 모든 항목은 근거 추적 가능해야 한다.",
  "type": "object",
  "required": [
    "prescription_id",
    "user_id",
    "generated_at",
    "diagnosis",
    "weekly_goal",
    "daily_tasks",
    "evidence_refs",
    "triggered_rule_keys"
  ],
  "properties": {
    "prescription_id": { "type": "string" },
    "user_id": { "type": "string" },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "diagnosis": {
      "type": "object",
      "required": ["summary", "risk_level"],
      "properties": {
        "summary": { "type": "string" },
        "risk_level": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "risk_drivers": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "weekly_goal": {
      "type": "object",
      "required": ["goal_text", "verification_metric"],
      "properties": {
        "goal_text": { "type": "string" },
        "verification_metric": { "type": "string" }
      },
      "additionalProperties": false
    },
    "daily_tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["task_text"],
        "properties": {
          "task_text": { "type": "string" },
          "subject": {
            "type": "string",
            "enum": ["accounting", "tax", "mixed"]
          },
          "estimated_minutes": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "concepts_to_review": {
      "type": "array",
      "items": { "type": "string" }
    },
    "problems_to_solve": {
      "type": "array",
      "items": { "type": "string" },
      "description": "problem_id 목록."
    },
    "problems_to_skip": {
      "type": "array",
      "items": { "type": "string" }
    },
    "triggered_rule_keys": {
      "type": "array",
      "description": "이 처방을 발동시킨 decision_rule.rule_key 목록.",
      "items": { "type": "string" }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "description": "근거 추적용 참조. 처방 검증 가능성의 핵심.",
      "items": {
        "type": "object",
        "required": ["ref_type", "ref_id"],
        "properties": {
          "ref_type": {
            "type": "string",
            "enum": [
              "decision_rule",
              "success_case",
              "problem_intelligence",
              "extracted_signal",
              "user_state"
            ]
          },
          "ref_id": { "type": "string" },
          "note": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
